---
import { SITE_DATA } from "../config";
import SocialTags from "./SocialTags.astro";
import { useTranslations } from "../i18n/utils.js";

const { lang } = Astro.params;
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();

const licenseText =
    lang === "es"
        ? "Plantilla por Eric de Sojo Vilches. Licencia CC BY-NC-SA 4.0: Uso libre no comercial, requiere atribución."
        : "Template by Eric de Sojo Vilches. Licensed under CC BY-NC-SA 4.0: Free for non-commercial use, attribution required.";
---

<footer class="w-full h-fit py-10 mt-20 border-t border-white/10 bg-surface-950">
    <div
        class="container h-fit mx-auto px-4 flex flex-col items-center justify-center gap-6"
    >
        <div class="flex flex-col items-center gap-2 text-center">
            <h2 class="text-2xl font-bold text-white tracking-tight">
                {SITE_DATA.name}
            </h2>
            <p class="text-surface-400 text-sm max-w-md">
                {t("hero.subtitle")}
            </p>
        </div>

        <div class="flex flex-wrap justify-center gap-4">
            {
                SITE_DATA.socials.map((social) => (
                    <SocialTags
                        name={social.name}
                        href={social.type + social.url}
                        icon={social.icon}
                    />
                ))
            }
        </div>

        <div
            class="w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent max-w-xs"
        >
        </div>

        <div
            class="w-1/2 flex flex-col items-center gap-2 text-center relative"
            id="copyright"
        >
            <p class="text-surface-500 text-xs text-center">
                &copy; {currentYear}
            </p>
            <div class="
            flex flex-col
            text-surface-500 text-xs
            absolute top-[-50px] p-2 border border-primary-500 rounded-md
            bg-surface-800 backdrop-blur-md w-64 z-50 shadow-xl
            hidden
            "
            id="copyrightText"
            >
                <p>
                    {licenseText}
                </p>
                <hr class="my-2">
                <a class="text-primary-500 hover:underline text-center w-full" href="https://github.com/edesojo" target="_blank" rel="noopener noreferrer">Eric de Sojo Vilches</a>
            </div>

        </div>
    </div>
</footer>

<style>
    #copyright:hover #copyrightText {
        display: block;
    }
</style>
