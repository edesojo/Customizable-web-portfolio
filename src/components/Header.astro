---
import { useTranslations } from "../i18n/utils";
import { SITE_DATA } from "../config";
import { Icon } from "astro-icon/components";

const { pathname } = Astro.url;
const currentLang = pathname.startsWith("/en") ? "en" : "es";

const esPath = currentLang === "es" ? pathname : pathname.replace("/en", "/es");
const enPath = currentLang === "en" ? pathname : pathname.replace("/es", "/en");

const t = useTranslations(currentLang);

// Esto permite controlar exactamente el orden y qué secciones aparecen en el menú.
const navItems = [
    { label: t("nav.about"), href: "#sobre-mi" }, // Busca id="sobre-mi" en SobreMi.astro
    { label: t("nav.skills"), href: "#skills" }, // Busca id="skills" en Skills.astro
    { label: t("nav.education"), href: "#education" }, // Busca id="education" en Education.astro
    { label: t("nav.experience"), href: "#experience" }, // Busca id="experience" en Experience.astro
    { label: t("nav.projects"), href: "#projects" }, // Busca id="projects" en Projects.astro
];

---

<header
    class="sticky top-0 left-0 right-0 z-50 transition-all duration-300 
    bg-surface-950/80 backdrop-blur-md 
    max-h-[100vh]
    backdrop-blur-md
    "
>
    <div
        class="container mx-auto px-6 h-20 flex items-center justify-between relative"
    >
        <!-- Logo -->
        <a
            href="#"
            class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-primary-400 to-primary-200"
        >
            {SITE_DATA.name}
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden md:flex items-center gap-8">
            <!-- Usamos .map() para mostrar la lista automáticamente -->
            <ul class="flex gap-6">
                {
                    navItems.map((item) => (
                        <li>
                            <a
                                href={item.href}
                                class="text-sm font-medium text-surface-300 hover:text-white transition-colors"
                            >
                                {item.label}
                            </a>
                        </li>
                    ))
                }
            </ul>

            <!-- Dictionary / Lang Switcher -->
            <div
                class="flex items-center gap-1 p-1 rounded-lg border border-white/10 bg-white/5"
            >
                <a
                    href={esPath}
                    class={`px-2 py-1 rounded text-xs font-bold transition-all
                ${
                    currentLang === "es"
                        ? "bg-primary-500 text-white shadow-sm"
                        : "text-surface-400 hover:text-white"
                }`}
                >
                    ES
                </a>
                <a
                    href={enPath}
                    class={`px-2 py-1 rounded text-xs font-bold transition-all
                ${
                    currentLang === "en"
                        ? "bg-primary-500 text-white shadow-sm"
                        : "text-surface-400 hover:text-white"
                }`}
                >
                    EN
                </a>
            </div>
        </nav>

        <!-- Mobile Menu Logic -->
        <input type="checkbox" id="mobile-menu-control" class="hidden peer" />

        <!-- Hamburger Button -->
        <label
            for="mobile-menu-control"
            class="md:hidden text-white cursor-pointer z-50 p-2 hover:bg-white/10 rounded-lg transition-colors"
        >
            <Icon name="burgerMenu" class="w-6 h-6"/>
        </label>

        <!-- Mobile Menu Overlay -->
        <div
            class="
            hidden peer-checked:block fixed inset-0 top-20 bg-surface-950/95 z-40
            translate-x-full 
            peer-checked:translate-x-0 transition-transform duration-300
            flex flex-col items-center justify-start pt-10
            md:hidden border-t border-white/10 bg-surface-950 h-[calc(100vh)] backdrop-blur-md
            "
        >
            <ul class="flex flex-col items-center gap-8 w-full">
                {
                    navItems.map((item) => (
                        <li class="w-full text-center">
                            <a
                                href={item.href}
                                class="block w-full py-4 text-2xl font-medium text-white hover:text-primary-400 hover:bg-white/5 transition-colors"
                                onclick="document.getElementById('mobile-menu-control').checked = false;"
                            >
                                {item.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
            <!-- Mobile Lang Switcher -->
            <div
                class="flex items-center gap-4 p-2 rounded-xl border border-white/10 bg-white/5 mt-[5rem] mb-10 w-fit m-auto"
            >
                <a
                    href={esPath}
                    class={`px-4 py-2 rounded-lg text-sm font-bold transition-all ${
                        currentLang === "es"
                            ? "bg-primary-500 text-white shadow-sm"
                            : "text-surface-400 hover:text-white"
                    }`}
                >
                    ESPAÑOL
                </a>
                <a
                    href={enPath}
                    class={`px-4 py-2 rounded-lg text-sm font-bold transition-all ${
                        currentLang === "en"
                            ? "bg-primary-500 text-white shadow-sm"
                            : "text-surface-400 hover:text-white"
                    }`}
                >
                    ENGLISH
                </a>
            </div>
        </div>
    </div>
</header>
