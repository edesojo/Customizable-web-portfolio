---
import { Icon } from "astro-icon/components";

interface Props {
    company: string;
    role: string;
    startDate: string;
    endDate: string;
    description: string;
    icon: string;
    technologies?: string[];
}

const {
    company,
    role,
    startDate,
    endDate,
    description,
    icon,
    technologies = [],
} = Astro.props;
---

<div
    class="group relative w-full md:w-3/4 lg:w-full mx-auto p-[1px] rounded-2xl bg-gradient-to-r from-white/10 via-white/5 to-white/10 hover:from-primary-500/50 hover:via-primary-400/30 hover:to-primary-500/50 transition-all duration-500 shadow-lg hover:shadow-primary-500/20"
>
    <div
        class="relative flex flex-col md:flex-row gap-6 p-6 md:p-8 rounded-2xl bg-surface-900/90 backdrop-blur-xl h-full items-start md:items-center"
    >
        <!-- Icon Section -->
        <div
            class="flex-shrink-0
            w-16 h-16 md:w-20 md:h-20
            rounded-2xl
            bg-surface-800/50
            border border-white/5
            flex items-center justify-center
            group-hover:scale-110 transition-transform duration-300 ease-out
            shadow-inner"
        >
            <Icon
                name={icon}
                class="w-8 h-8 md:w-10 md:h-10 text-primary-300"
            />
        </div>

        <!-- Content Section -->
        <div class="flex-grow flex flex-col gap-2 w-full">
            <div
                class="flex flex-col md:flex-row md:justify-between md:items-start gap-1"
            >
                <div>
                    <h3
                        class="text-xl md:text-2xl font-bold text-white group-hover:text-primary-300 transition-colors"
                    >
                        {role}
                    </h3>
                    <h4 class="text-lg font-medium text-primary-400/90">
                        {company}
                    </h4>
                </div>

                <div
                    class="flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 self-start md:self-auto"
                >
                    <span
                        class="w-2 h-2 rounded-full bg-primary-500 animate-pulse"
                    ></span>
                    <span
                        class="text-xs md:text-sm font-mono text-surface-300 tracking-wide uppercase"
                    >
                        {startDate} — {endDate}
                    </span>
                </div>
            </div>

            <p
                class="text-surface-300 text-sm md:text-base leading-relaxed mt-2 max-w-3xl"
            >
                {description}
            </p>

            {
                technologies.length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-white/5">
                        {technologies.map((tech) => (
                            <span
                                class="
                            px-2.5 py-0.5 
                            rounded-md 
                            text-xs font-medium 
                            bg-primary-500/10 text-primary-200 
                            border border-primary-500/20
                            hover:bg-primary-500/20 transition-colors
                        "
                            >
                                {tech}
                            </span>
                        ))}
                    </div>
                )
            }
        </div>
    </div>
</div>
