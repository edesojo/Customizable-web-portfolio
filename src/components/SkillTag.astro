---
import { Icon } from 'astro-icon/components';
interface Props {
    label: string;
    icon?: string;
}

const { label, icon } = Astro.props;
---

<div class=" skill-tag
flex flex-col items-center justify-center gap-1 
w-[75px] px-2 aspect-square 
bg-white/5 backdrop-blur-md shadow-2xl rounded-xl border border-white/10 
hover:scale-105 transition-all duration-300 text-tag">
    {
        (icon != null) 
        ? <Icon name={icon} class="w-1/2 h-1/2" />
        : null
    }
    <h3 class="text-sm font-bold leading-none">{label}</h3>
</div>

<style>
    .skill-tag:hover {
        perspective: 1000px;
        transform: rotateX(-15deg) translate(0, -5px);
        box-shadow: -2px 6px 0px var(--color-tag);
        background-color: var(--color-tag);
        color: black;
        border: 2px solid black;
        box-sizing: border-box;
    }
</style>