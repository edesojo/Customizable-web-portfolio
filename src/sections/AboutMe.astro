---
interface Props {
    title: string;
    text1: string;
    text2: string;
    text3: string;
}

const { title, text1, text2, text3 } = Astro.props;
---

<section
    id="sobre-mi"
    class="relative w-full xl:w-full p-5 md:p-20 flex flex-col items-center md:items-start justify-center overflow-hidden"
>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 w-full items-start">
        <!-- Text Content -->
        <div class="flex flex-col">
            <h2
                class="text-4xl md:text-5xl font-bold bg-clip-text text-transparent
                bg-gradient-to-r from-primary-100 to-primary-600 reveal-text
                opacity-0 translate-y-4 will-change-transform"
            >
                {title}
            </h2>

            <div
                class="space-y-4 text-lg md:text-xl text-color font-medium
                leading-relaxed reveal-text delay-100 opacity-0 translate-y-4
                will-change-transform"
            >
                <p class="text-lg md:text-3xl font-bold">{text1}</p>
                <p class="text-lg md:text-xl">{text2}</p>
                <p class="text-lg md:text-xl">{text3}</p>
            </div>
        </div>

        <!-- Visual / Glass Card -->
        <div
            class="flex items-center justify-center lg:justify-end reveal-card opacity-0 md:translate-x-4
            will-change-transform"
        >
            <div
                class="relative w-full max-w-md aspect-square rounded-3xl border
                border-white/10 bg-white/5 backdrop-blur-md shadow-2xl p-8
                flex flex-col justify-between overflow-hidden group hover:border-primary-500/30 transition-colors duration-500"
            >
                <!-- Card Inner Glow -->
                <div
                    class="absolute inset-0 bg-gradient-to-br from-primary-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                >
                </div>

                <div class="relative z-10">
                    <span class="text-6xl">🚀</span>
                </div>

                <div class="relative z-10 space-y-2">
                    <div class="h-2 w-24 bg-white/20 rounded-full"></div>
                    <div class="h-2 w-32 bg-white/10 rounded-full"></div>
                    <div class="h-2 w-16 bg-white/10 rounded-full"></div>
                </div>

                <!-- Decor Elements -->
                <div
                    class="absolute top-1/2 right-0 -translate-y-1/2 mr-[-40%] w-[80%] h-[80%] border border-white/5 rounded-full animate-spin-slow"
                >
                </div>
                <div
                    class="absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary-600/20 blur-[50px] rounded-full"
                >
                </div>
            </div>
        </div>
    </div>
</section>
