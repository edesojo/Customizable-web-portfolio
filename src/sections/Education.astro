---
import LaboralExperienceTag from "../components/LaboralExperienceTag.astro";
import { translateEducation } from "../i18n/utils";

interface Props {
    title: string;
    subtitle: string;
    lang: string;
}

const { title, subtitle, lang } = Astro.props;
const education = translateEducation(lang);
---

<section
    id="education"
    class="relative w-full min-h-[50vh] flex flex-col items-center justify-center py-20 px-4 gap-8"
>
    <!-- Background Glow -->
    <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
        w-[60vw] h-[60vw] bg-secondary-900/10 blur-[120px] rounded-full -z-10 pointer-events-none"
    >
    </div>

    <div class="text-center space-y-4">
        <h2
            class="text-4xl md:text-5xl font-bold text-white reveal-text opacity-0 translate-y-4 will-change-transform"
        >
            {title}
        </h2>
        <h3
            class="text-xl md:text-2xl bg-clip-text text-transparent bg-gradient-to-r from-white via-primary-200 to-primary-400 font-medium reveal-text delay-100 opacity-0 translate-y-4 will-change-transform"
        >
            {subtitle}
        </h3>
    </div>

    <div class="w-full flex flex-col items-center gap-6 max-w-5xl">
        {
            education.map(
                (
                    edu: {
                        institution: string;
                        degree: string;
                        startDate: string;
                        endDate: string;
                        description: string;
                        technologies: string[];
                        icon?: string;
                    },
                    index: number,
                ) => (
                    <div
                        class="w-full reveal-card opacity-0 translate-y-4 will-change-transform"
                        style={`transition-delay: ${index * 100}ms`}
                    >
                        <LaboralExperienceTag
                            company={edu.institution}
                            role={edu.degree}
                            startDate={edu.startDate}
                            endDate={edu.endDate}
                            description={edu.description}
                            technologies={edu.technologies}
                            icon={edu.icon || "book"}
                        />
                    </div>
                ),
            )
        }
    </div>
</section>

<style>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fadeInUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        opacity: 0; /* Initial state hidden */
    }
</style>
