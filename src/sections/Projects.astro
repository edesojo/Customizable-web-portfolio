---
import Project from "../components/Project.astro";
import { translateProjects } from "../i18n/utils";

interface Props {
    title: string;
    subtitle: string;
    lang: string;
}

const { title, subtitle, lang } = Astro.props;
const projects = translateProjects(lang);
---

<section
    id="projects"
    class="relative
    w-full
    flex flex-col items-center justify-center
    py-20 px-4"
>
    <!-- Background Glow (Optional, keeps consistency) -->
    <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
    w-[60vw] h-[60vw] bg-primary-900/10 blur-[120px] rounded-full -z-10 pointer-events-none"
    >
    </div>

    <div class="text-center space-y-4 mb-12">
        <h2
            class="text-4xl md:text-5xl font-bold text-white reveal-text opacity-0 translate-y-4 will-change-transform"
        >
            {title}
        </h2>
        <h3
            class="text-xl md:text-2xl bg-clip-text text-transparent bg-gradient-to-r from-white via-primary-200 to-primary-400 font-medium reveal-text delay-100 opacity-0 translate-y-4 will-change-transform"
        >
            {subtitle}
        </h3>
    </div>

    <div class="w-full flex flex-wrap justify-center gap-8 max-w-7xl">
        {
            projects.map(
                (
                    project: {
                        title: string;
                        description: string;
                        date: string;
                        technologies: string[];
                        repoLink: string;
                        image: string;
                        linkIcon: string;
                    },
                    index: number,
                ) => (
                    <div
                        class="reveal-card opacity-0 translate-y-4 will-change-transform"
                        style={`transition-delay: ${index * 100}ms`}
                    >
                        <Project
                            title={project.title}
                            description={project.description}
                            date={project.date}
                            technologies={project.technologies}
                            repoLink={project.repoLink}
                            image={project.image}
                            linkIcon={project.linkIcon}
                            lang={lang}
                        />
                    </div>
                ),
            )
        }
    </div>
</section>
